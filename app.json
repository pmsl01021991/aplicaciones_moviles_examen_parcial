{
  "expo": {
    "name": "examen_parcial",
    "slug": "examen_parcial",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "examenpreliminar",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },

    "web": {
      "output": "static"
    },

    "plugins": [
      "expo-router"
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}